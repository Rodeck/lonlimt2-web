{
  "name": "lonlimt2-webpage",
  "version": "1.0.0",
  "description": "LonliMT2 game server portal",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build:css": "tailwindcss -i src/styles/input.css -o public/css/style.css --minify",
    "build:css:dev": "tailwindcss -i src/styles/input.css -o public/css/style.css",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "eta": "^3.5.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
