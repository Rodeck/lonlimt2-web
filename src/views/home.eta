<% layout("layouts/base") %>

<!-- ── Hero Section (US1) ──────────────────────────────────── -->
<section class="hero" aria-label="Hero">

  <!-- Hero image with overlaid text -->
  <div class="hero-image-wrapper">
    <img
      src="/static/images/main-image.png"
      alt=""
      class="hero-main-image"
      aria-hidden="true"
    />

    <div class="hero-image-overlay">
      <!-- Atmospheric decorative emblem -->
      <div class="hero-emblem" aria-hidden="true">
        <div class="hero-emblem-ring"></div>
        <div class="hero-emblem-ring-inner"></div>
        <div class="hero-emblem-diamond"></div>
      </div>

      <!-- Tagline -->
      <h1 class="hero-title">
        <%= it.hero.tagline %><br />
        <span class="text-gold"><%= it.hero.taglineSub %></span>
      </h1>

      <!-- Gold divider -->
      <div class="hero-divider" aria-hidden="true"></div>

      <!-- Description -->
      <p class="hero-description">
        <%= it.hero.description %>
      </p>

      <!-- Call to action -->
      <div class="hero-actions">
        <a href="<%= it.hero.ctaHref %>" class="hero-cta">
          <%= it.hero.ctaText %>
        </a>
        <% if (it.hero.patcherUrl) { %>
        <a href="<%= it.hero.patcherUrl %>" class="hero-cta-secondary" download>
          <%= it.hero.downloadText %>
        </a>
        <% } %>
      </div>
    </div>
  </div>

</section>
